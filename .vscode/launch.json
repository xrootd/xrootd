{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "XRootD Mirage Server",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/build/bin/xrootd",
            "args": [
                "-c",
                "${workspaceFolder}/tests/XRootD/mirage.cfg",
                "-n",
                "mirage"
            ],
            "stopAtEntry": false,
            "cwd": "/tmp",
            "environment": [
                {
                    "name": "SOURCE_DIR",
                    "value": "${workspaceFolder}/tests/XRootD"
                }
            ],
            "externalConsole": false,
            "MIMode": "gdb"
        },
        {
            "name": "XRootD Mirage Tests",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/build/bin/xrdossmirage-unit-tests",
            "stopAtEntry": false,
            "cwd": "/tmp",
            "externalConsole": false,
            "MIMode": "gdb"
        }
    ]
}